{
  "version": 2,
  "routes": [
    {
      "src": "/api/betaling-start",
      "dest": "/api/betaling-start.js"
    },
    {
      "src": "/api/paynl-exchange",
      "dest": "/api/paynl-exchange.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://bylder.com" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
